#!/bin/sh
set -e 

echo "Sekrets: Running post-removal cleanup..."

case "$1" in
    remove|purge)
        # Get the real user
        if [ -n "$SUDO_USER" ]; then
            USER="$SUDO_USER"
        else
            USER=$(logname 2>/dev/null || echo "$USER")
        fi

        SEKRETS_FILE_LOCAL="/home/$USER/.local/share/sekrets/sekrets.enc"
        BACKUP_DIR="/home/$USER/sekrets_backup"

        echo "Removing Sekrets configuration and data directories for user: $USER"

        # Find sekrets.enc dynamically inside ~/snap/sekrets/
        SEKRETS_FILE_SNAP=$(find "/home/$USER/snap/sekrets" -type f -name "sekrets.enc" 2>/dev/null | head -n 1)

        # Check if running interactively
        is_interactive() {
            [ -t 0 ] && [ -t 1 ]
        }

        move_sekret_file() {
            FILE_PATH=$1
            
            if [ -f "$FILE_PATH" ]; then
                if is_interactive; then
                    echo "⚠️ WARNING: Your secrets file ($FILE_PATH) will be deleted!"
                    echo "Would you like to copy it to a safe location before removal? (y/N)"
                    read -r confirm
                    if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
                        echo "Enter the full path where you want to save sekrets.enc:"
                        read -r backup_location
                        if [ -d "$backup_location" ]; then
                            mv "$FILE_PATH" "$backup_location/sekrets.enc"
                            echo "✅ sekrets.enc has been moved to $backup_location"
                        else
                            echo "❌ Invalid directory. Moving to default backup: $BACKUP_DIR"
                            mkdir -p "$BACKUP_DIR"
                            mv "$FILE_PATH" "$BACKUP_DIR/"
                            echo "✅ sekrets.enc moved to $BACKUP_DIR"
                        fi
                    else
                        echo "❗ Proceeding with removal without backup."
                    fi
                else
                    echo "⚠️ WARNING: sekrets.enc ($FILE_PATH) is about to be deleted."
                    echo "Moving to default backup location: $BACKUP_DIR"
                    mkdir -p "$BACKUP_DIR"
                    mv "$FILE_PATH" "$BACKUP_DIR/"
                    echo "✅ sekrets.enc has been moved to $BACKUP_DIR"
                fi
            fi
        }

        # Check and move both local and snap directory files
        move_sekret_file "$SEKRETS_FILE_LOCAL"
        if [ -n "$SEKRETS_FILE_SNAP" ]; then
            move_sekret_file "$SEKRETS_FILE_SNAP"
        fi

        # Remove Sekrets config and data directories
        sudo -H -u "$USER" bash -c 'rm -rf ~/.local/share/sekrets ~/.config/sekrets ~/snap/sekrets' || true
        ;;
esac
